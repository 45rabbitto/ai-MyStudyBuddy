    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "4f329244"
      },
      "source": [
        "## Mengambil Data dari Kaggle (IndoSum)"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "collapsed": true,
        "id": "e58d2a1f"
      },
      "source": [
        "dataset_id = 'linkgish/indosum'\n",
        "\n",
        "os.makedirs('./indosum_data', exist_ok=True)\n",
        "\n",
        "print(f\"Downloading dataset: {dataset_id}...\")\n",
        "!kaggle datasets download -d {dataset_id} -p ./indosum_data\n",
        "\n",
        "print(\"Unzipping dataset...\")\n",
        "!unzip -o ./indosum_data/indosum.zip -d ./indosum_data\n",
        "\n",
        "print(\"Dataset downloaded and unzipped to './indosum_data/'\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "collapsed": true,
        "id": "0a083056"
      },
      "source": [
        "data_dir = './indosum_data/indosum/'\n",
        "\n",
        "all_data = []\n",
        "\n",
        "for filename in os.listdir(data_dir):\n",
        "    if filename.endswith('.jsonl'):\n",
        "        filepath = os.path.join(data_dir, filename)\n",
        "        print(f\"Loading data from {filepath}...\")\n",
        "        with open(filepath, 'r', encoding='utf-8') as f:\n",
        "            for line in f:\n",
        "                all_data.append(json.loads(line))\n",
        "\n",
        "df_indosum_kaggle = pd.DataFrame(all_data)\n",
        "\n",
        "print(\"Data loaded successfully into a pandas DataFrame.\")\n",
        "print(\"First 5 rows of the IndoSum data:\")\n",
        "display(df_indosum_kaggle.head())\n",
        "\n",
        "print(f\"DataFrame shape: {df_indosum_kaggle.shape}\")\n",
        "print(\"DataFrame info:\")\n",
        "df_indosum_kaggle.info()"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "collapsed": true,
        "id": "8a330f02"
      },
      "source": [
        "df_indosum = df_indosum_kaggle.head(5000)\n",
        "\n",
        "print(f\"Shape of the new DataFrame (df_5000): {df_indosum.shape}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Mengambil Data dari Wikipedia"
      ],
      "metadata": {
        "id": "KN0F7mL0R7DE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# setup wikipedia indonesia\n",
        "wiki = wikipediaapi.Wikipedia(\n",
        "    language='id',\n",
        "    user_agent='MyStudyBuddy/1.0'\n",
        ")\n",
        "\n",
        "# kategori yang ingin diambil\n",
        "categories = [\n",
        "    \"Kategori:Biologi\",\n",
        "    \"Kategori:Fisika\",\n",
        "    \"Kategori:Matematika\",\n",
        "    \"Kategori:Teknologi\",\n",
        "    \"Kategori:Pendidikan\",\n",
        "    \"Kategori:Geografi\",\n",
        "    \"Kategori:Ilmu\",\n",
        "    \"Kategori:Seni\",\n",
        "    \"Kategori:Filsafat\",\n",
        "]\n",
        "\n",
        "# cleaning text\n",
        "def clean_text(text):\n",
        "\n",
        "    text = re.sub(r\"==.*?==\", \"\", text)\n",
        "    text = re.sub(r\"\\n+\", \"\\n\", text)\n",
        "    text = re.sub(r\"\\s+\", \" \", text)\n",
        "    return text.strip()\n",
        "\n",
        "data = []\n",
        "\n",
        "visited = set()\n",
        "for category_name in categories:\n",
        "    print(f\"\\nMengambil kategori: {category_name}\")\n",
        "    category_page = wiki.page(category_name)\n",
        "    members = category_page.categorymembers\n",
        "    for title, page in tqdm(members.items()):\n",
        "        if title in visited:\n",
        "            continue\n",
        "        visited.add(title)\n",
        "\n",
        "        # hanya artikel utama\n",
        "        if page.ns != wikipediaapi.Namespace.MAIN:\n",
        "            continue\n",
        "        try:\n",
        "            full_text = clean_text(page.text)\n",
        "            # skip artikel terlalu pendek\n",
        "            if len(full_text) < 500:\n",
        "                continue\n",
        "            # ambil paragraf pertama panjang\n",
        "            paragraphs = full_text.split(\"\\n\")\n",
        "            summary = \"\"\n",
        "            for p in paragraphs:\n",
        "                if len(p.strip()) > 100:\n",
        "                    summary = p.strip()\n",
        "                    break\n",
        "\n",
        "            data.append({\n",
        "                \"title\": title,\n",
        "                \"document\": full_text,\n",
        "                \"summary\": summary,\n",
        "                \"category\": category_name\n",
        "            })\n",
        "\n",
        "        except Exception as e:\n",
        "            print(f\"Error {title}: {e}\")\n",
        "\n",
        "# simpan dataset\n",
        "df_wikipedia = pd.DataFrame(data)"
      ],
      "metadata": {
        "id": "JFrdxofpTCxK"
      },
      "execution_count": null,
      "outputs": []
    },
