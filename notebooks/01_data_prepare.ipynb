    {
      "cell_type": "markdown",
      "source": [
        "# Mengambil Data dari Wikipedia"
      ],
      "metadata": {
        "id": "KN0F7mL0R7DE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# setup wikipedia indonesia\n",
        "wiki = wikipediaapi.Wikipedia(\n",
        "    language='id',\n",
        "    user_agent='MyStudyBuddy/1.0'\n",
        ")\n",
        "\n",
        "# kategori yang ingin diambil\n",
        "categories = [\n",
        "    \"Kategori:Biologi\",\n",
        "    \"Kategori:Fisika\",\n",
        "    \"Kategori:Matematika\",\n",
        "    \"Kategori:Teknologi\",\n",
        "    \"Kategori:Pendidikan\",\n",
        "    \"Kategori:Geografi\",\n",
        "    \"Kategori:Ilmu\",\n",
        "    \"Kategori:Seni\",\n",
        "    \"Kategori:Filsafat\",\n",
        "]\n",
        "\n",
        "# cleaning text\n",
        "def clean_text(text):\n",
        "\n",
        "    text = re.sub(r\"==.*?==\", \"\", text)\n",
        "    text = re.sub(r\"\\n+\", \"\\n\", text)\n",
        "    text = re.sub(r\"\\s+\", \" \", text)\n",
        "    return text.strip()\n",
        "\n",
        "data = []\n",
        "\n",
        "visited = set()\n",
        "for category_name in categories:\n",
        "    print(f\"\\nMengambil kategori: {category_name}\")\n",
        "    category_page = wiki.page(category_name)\n",
        "    members = category_page.categorymembers\n",
        "    for title, page in tqdm(members.items()):\n",
        "        if title in visited:\n",
        "            continue\n",
        "        visited.add(title)\n",
        "\n",
        "        # hanya artikel utama\n",
        "        if page.ns != wikipediaapi.Namespace.MAIN:\n",
        "            continue\n",
        "        try:\n",
        "            full_text = clean_text(page.text)\n",
        "            # skip artikel terlalu pendek\n",
        "            if len(full_text) < 500:\n",
        "                continue\n",
        "            # ambil paragraf pertama panjang\n",
        "            paragraphs = full_text.split(\"\\n\")\n",
        "            summary = \"\"\n",
        "            for p in paragraphs:\n",
        "                if len(p.strip()) > 100:\n",
        "                    summary = p.strip()\n",
        "                    break\n",
        "\n",
        "            data.append({\n",
        "                \"title\": title,\n",
        "                \"document\": full_text,\n",
        "                \"summary\": summary,\n",
        "                \"category\": category_name\n",
        "            })\n",
        "\n",
        "        except Exception as e:\n",
        "            print(f\"Error {title}: {e}\")\n",
        "\n",
        "# simpan dataset\n",
        "df_wikipedia = pd.DataFrame(data)"
      ],
      "metadata": {
        "id": "JFrdxofpTCxK"
      },
      "execution_count": null,
      "outputs": []
