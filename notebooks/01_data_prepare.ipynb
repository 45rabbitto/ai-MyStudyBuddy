    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "8c4ccfec",
        "outputId": "cb4b709a-ab62-44e3-f086-d7e4beb4d4a2"
      },
      "source": [
        "def flatten_deep(nested_list):\n",
        "    flat_list = []\n",
        "    for item in nested_list:\n",
        "        if isinstance(item, list) and not isinstance(item, (str, bytes)):\n",
        "            flat_list.extend(flatten_deep(item))\n",
        "        else:\n",
        "            flat_list.append(str(item))\n",
        "    return flat_list\n",
        "\n",
        "# Prepare df_5000 (IndoSum)\n",
        "df_indosum_processed = df_indosum.copy()\n",
        "# flatten data paragraphs dan summary, rename kolom\n",
        "df_indosum_processed['text'] = df_indosum_processed['paragraphs'].apply(lambda x: ' '.join(flatten_deep(x)))\n",
        "df_indosum_processed['summary'] = df_indosum_processed['summary'].apply(lambda x: ' '.join(flatten_deep(x)))\n",
        "# save data\n",
        "df_indosum_processed = df_indosum_processed[['text', 'summary']].copy()\n",
        "df_indosum_processed['source'] = 'indosum'\n",
        "\n",
        "\n",
        "# Prepare df_wiki_edu\n",
        "df_wiki_edu_processed = df_wikipedia[['document', 'summary']].copy()\n",
        "df_wiki_edu_processed.rename(columns={'document': 'text'}, inplace=True)\n",
        "df_wiki_edu_processed['source'] = 'wikipedia'\n",
        "\n",
        "# Prepare data XLSum\n",
        "df_xlsum_processed = df_xlsum[['text', 'summary']].copy()\n",
        "df_xlsum_processed['source'] = 'xlsum'\n",
        "\n",
        "df = pd.concat([df_indosum_processed, df_wiki_edu_processed, df_xlsum_processed], ignore_index=True)\n",
        "\n",
        "print(f\"Shape of combined DataFrame: {df.info()}\")"
      ],
