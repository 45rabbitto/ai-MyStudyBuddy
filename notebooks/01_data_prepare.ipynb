      }
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "d2627339"
      },
      "source": [
        "# info masing-masing data\n",
        "print(\"Info DataFrame IndoSum:\")\n",
        "display(df_indosum.info()) # ambil kolom paragraphs dan summary\n",
        "print(\"Info DataFrame Wikipedia:\")\n",
        "display(df_wikipedia.info()) # ambil data document dan summary\n",
        "print(\"Info DataFrame XL-Sum:\")\n",
        "display(df_xlsum.info()) # ambil data text dan summary"
      ],
